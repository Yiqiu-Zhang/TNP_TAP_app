""" + linedivide


####################################################################################################
# TAP FLAG THRESHOLDS (Raybould et al. 2019, calibrated for antibodies)
def assign_flag(metric, value):

    # Total CDR Length (L) - includes both heavy and light chains
    if metric == "L":
        if value < 38 or value > 84:
            return "red"
        elif value >= 38 and value <= 43:
            return "amber"
        elif value >= 79 and value <= 84:
            return "amber"
        else:
            return "green"

    # CDRH3 Length (L3)
    elif metric == "L3":
        if value < 5 or value > 26:
            return "red"
        elif value >= 5 and value <= 8:
            return "amber"
        elif value >= 23 and value <= 26:
            return "amber"
        else:
            return "green"

    # CDRH3 compactness (C)
    elif metric == "C":
        if value < 0.56 or value > 1.61:
            return "red"
        elif value >= 0.56 and value <= 0.81:
            return "amber"
        elif value >= 1.57 and value <= 1.61:
            return "amber"
        else:
            return "green"

    # Patches of surface hydrophobicity (PSH)
    elif metric == "PSH":
        if value < 53 or value > 98:
            return "red"
        elif value >= 53 and value <= 62:
            return "amber"
        elif value >= 91 and value <= 98:
            return "amber"
        else:
            return "green"

    # Patches of positive charge (PPC)
    elif metric == "PPC":
        if value > 2.56:
            return "red"
        elif value >= 1.48 and value <= 2.56:
            return "amber"
        else:
            return "green"

    # Patches of negative charge (PNC)
    elif metric == "PNC":
        if value > 2.91:
            return "red"
        elif value >= 2.05 and value <= 2.91:
            return "amber"
        else:
            return "green"


####################################################################################################
# Remove hydrogens from ImmuneBuilder output models
import re as _re
from Bio.PDB import PDBParser, PDBIO, Select

_hydrogen = _re.compile("[123 ]*H.*")

class RemoveHydrogen(Select):
    def accept_atom(self, atom):
        name = atom.get_id()
        return 0 if _hydrogen.match(name) else 1


def pdb_remove_hydrogens(input_pdb):
    try:
        pdb = PDBParser().get_structure("antibody", input_pdb)
        io = PDBIO()
        io.set_structure(pdb)
        output_model = f'{input_pdb[:-4]}.pdb'
        io.save(output_model, RemoveHydrogen())
    except Exception as e:
        print(e)


####################################################################################################
# Main function that runs TAP on antibody sequences (VH + VL)
def main(heavy_name, heavy_sequence, light_name, light_sequence, h_scale, output, web, verbose=False):

    print(header)
    print("TAP is running in ANTIBODY mode with both heavy and light chains.\n")

    CDR_data_loc = os.path.join(output, "Outputs")
    Model_data_loc = os.path.join(output, "Final_Models")
    abbrev_name = heavy_name[:-2] if heavy_name.endswith("_H") else heavy_name

    print("TAP is running on sequence %s" % abbrev_name)

    logfile = os.path.join(output, abbrev_name + "_TAP.log")
    with open(logfile, "w") as fo:

        fo.write("The TAP job initialised successfully for " + abbrev_name + ".\n")
        fo.write("It will calculate total CDR length (H+L), CDRH3 length, CDRH3 compactness, "
                 "and patches of surface hydrophobicity and charge across the full Fv.\n\n"
                 "--------------------------------------------------------------\n\n")

        if verbose:
            print("\nAnalysing CDR loops...\n\n")

        # ---- Heavy chain CDR analysis ----
        try:
            heavy_cdr_dict, heavy_len_dict = tap_region_and_aa_dicts(
                heavy_name, heavy_sequence, "H", verbose=verbose)
            fo.write("TAP managed to number the heavy chain sequence with ANARCI\n")
        except Exception:
            print("TAP could not number the heavy chain sequence %s with ANARCI" % abbrev_name)
            fo.write("TAP failed to number the heavy chain sequence with ANARCI\n")
            return

        # ---- Light chain CDR analysis ----
        try:
            light_cdr_dict, light_len_dict = tap_region_and_aa_dicts(
                light_name, light_sequence, "L", verbose=verbose)
            fo.write("TAP managed to number the light chain sequence with ANARCI\n")
        except Exception:
            print("TAP could not number the light chain sequence %s with ANARCI" % light_name)
            fo.write("TAP failed to number the light chain sequence with ANARCI\n")
            return

        # Calculate total CDR length (H+L)
        heavy_loops = ['cdrh1', 'cdrh2', 'cdrh3']
        light_loops = ['cdrl1', 'cdrl2', 'cdrl3']

        total_heavy_cdr_length = sum(heavy_len_dict['imgt'][loop] for loop in heavy_loops)
        total_light_cdr_length = sum(light_len_dict['imgt'][loop] for loop in light_loops)
        total_imgt_cdr_length = total_heavy_cdr_length + total_light_cdr_length

        imgt_cdrh3_length = heavy_len_dict['imgt']['cdrh3']
        imgt_cdrl3_length = light_len_dict['imgt']['cdrl3']

        # ---- Modelling with AntibodyBuilder2 ----
        if verbose:
            print(linedivide + "Calling AntibodyBuilder2 (ImmuneBuilder) to model your antibody\n\n")

        try:
            if os.path.exists(abbrev_name):
                shutil.rmtree(abbrev_name)
            os.mkdir(abbrev_name)

            cmd = ["AntibodyBuilder2",
                   "--heavy_sequence", heavy_sequence,
                   "--light_sequence", light_sequence,
                   "--output", os.path.join(abbrev_name, abbrev_name + ".pdb"),
                   "--n_threads", "1"]
            if verbose:
                cmd.append("--verbose")

            subprocess.run(cmd, check=True)
            fo.write("AntibodyBuilder2 (ImmuneBuilder) was able to generate a model\n")

            try:
                input_pdb = os.path.join(abbrev_name, abbrev_name) + ".pdb"
                pdb_remove_hydrogens(input_pdb)
                print("Removed all Hydrogens from AntibodyBuilder2 model")
            except Exception as e:
                print(e)

        except Exception as e:
            print("ERROR: AntibodyBuilder2 (ImmuneBuilder) failed to generate a model")
            fo.write("AntibodyBuilder2 (ImmuneBuilder) was unable to generate a model\n")
            print(e)
            return

        # Generate modelling_details
        try:
            from scripts.process_pdb import get_modelling_details
            modelling_details = get_modelling_details(
                os.path.join(abbrev_name, abbrev_name) + ".pdb",
                type='antibody', save=True)
            fo.write("Saved modelling_details.jsonp for AntibodyBuilder2 model\n")
        except Exception as e:
            print("ERROR: Failed to process output PDB. " + str(e))

        if os.path.exists(os.path.join("Raw_Model_Outputs", abbrev_name)):
            shutil.rmtree(os.path.join("Raw_Model_Outputs", abbrev_name))
        subprocess.call(["mv", abbrev_name, "Raw_Model_Outputs/" + str(abbrev_name)])
        subprocess.call(["cp",
                         "Raw_Model_Outputs/" + str(abbrev_name) + "/" + abbrev_name + ".pdb",
                         "Final_Models/" + str(abbrev_name) + "_AntibodyBuilder2_Model.pdb"])
        subprocess.call(["cp",
                         "Raw_Model_Outputs/" + str(abbrev_name) + "/modelling_details.jsonp",
                         "Final_Models/" + str(abbrev_name) + "_AntibodyBuilder2_Model_Details.json"])
        subprocess.call(["cp",
                         "Raw_Model_Outputs/" + str(abbrev_name) + "/sequence_liabilities.csv",
                         "Final_Models/" + str(abbrev_name) + "_AntibodyBuilder2_Sequence_Liabilities.json"])

        model_pdb_path = os.path.join(
            Model_data_loc, str(abbrev_name) + "_AntibodyBuilder2_Model.pdb")

        if verbose:
            print(linedivide + "AntibodyBuilder2 (ImmuneBuilder) successfully modelled your antibody.\n\n")

        # ---- CDR3 Compactness (heavy chain only) ----
        if verbose:
            print(linedivide + "Calculating CDRH3 compactness.\n\n")

        cdr3_compactness_rho = tap_compactness_calc(model_pdb_path, "imgt", verbose=verbose)
        if cdr3_compactness_rho is not None:
            cdr3_compactness = imgt_cdrh3_length / cdr3_compactness_rho
            fo.write("TAP was able to calculate a CDRH3 compactness score.\n")
            if verbose:
                print(linedivide + "TAP calculated CDRH3 compactness score.\n\n")
        else:
            cdr3_compactness = np.nan
            fo.write("TAP was not able to calculate a CDRH3 compactness score.\n")
            if verbose:
                print(linedivide + "TAP could not calculate CDRH3 compactness.\n\n")

        # ---- Surface Hydrophobicity and Charge (full Fv) ----
        if verbose:
            print(linedivide + "Calculating surface hydrophobicity and charge properties "
                  "at pH 7.4 (salt-bridge corrected) for the full Fv...\n\n")

        hydrophob_and_charge_dict = tap_hydrophob_and_charge_calc(
            h_scale, 7.4, model_pdb_path, "IG", "imgt", verbose=verbose)

        fo.write("TAP was able to calculate PSH, PPC and PNC scores.\n")

        #######################################################################################

        tap_dictionary = {}
        tap_dictionary['name'] = abbrev_name
        tap_dictionary['model_type'] = 'antibody'
        tap_dictionary['Total CDR Length'] = total_imgt_cdr_length
        tap_dictionary['Total CDR Length H'] = total_heavy_cdr_length
        tap_dictionary['Total CDR Length L'] = total_light_cdr_length
        tap_dictionary['CDRH3 Length'] = imgt_cdrh3_length
        tap_dictionary['CDRL3 Length'] = imgt_cdrl3_length
        tap_dictionary['CDRH3 Compactness'] = cdr3_compactness
        tap_dictionary['PSH'] = hydrophob_and_charge_dict[h_scale]['Patch_Hydrophob_CDR']
        tap_dictionary['PPC'] = hydrophob_and_charge_dict[h_scale]['Patch_Pos_Charge_CDR']
        tap_dictionary['PNC'] = hydrophob_and_charge_dict[h_scale]['Patch_Neg_Charge_CDR']

        tap_dictionary['Flags'] = {
            "L":   assign_flag("L", total_imgt_cdr_length),
            "L3":  assign_flag("L3", imgt_cdrh3_length),
            "C":   assign_flag("C", cdr3_compactness),
            "PSH": assign_flag("PSH", hydrophob_and_charge_dict[h_scale]['Patch_Hydrophob_CDR']),
            "PPC": assign_flag("PPC", hydrophob_and_charge_dict[h_scale]['Patch_Pos_Charge_CDR']),
            "PNC": assign_flag("PNC", hydrophob_and_charge_dict[h_scale]['Patch_Neg_Charge_CDR']),
        }

        fo.write("\n\nSummary Statistics for %s (TAP antibody mode):\n" % abbrev_name)
        fo.write("    Total IMGT CDR Length (H+L): %d (%s flag)\n"
                 % (tap_dictionary['Total CDR Length'], tap_dictionary['Flags']['L'].upper()))
        fo.write("      Heavy chain: %d\n" % tap_dictionary['Total CDR Length H'])
        fo.write("      Light chain: %d\n" % tap_dictionary['Total CDR Length L'])
        fo.write("    IMGT CDRH3 Length: %d (%s flag)\n"
                 % (tap_dictionary['CDRH3 Length'], tap_dictionary['Flags']['L3'].upper()))
        fo.write("    IMGT CDRL3 Length: %d\n" % tap_dictionary['CDRL3 Length'])
        fo.write("    IMGT CDRH3 Compactness: %f (%s flag)\n"
                 % (tap_dictionary['CDRH3 Compactness'], tap_dictionary['Flags']['C'].upper()))
        fo.write("    Patch CDR Surface Hydrophobicity (PSH): %f (%s flag)\n"
                 % (tap_dictionary['PSH'], tap_dictionary['Flags']['PSH'].upper()))
        fo.write("    Patch CDR Positive Charge (PPC): %f (%s flag)\n"
                 % (tap_dictionary['PPC'], tap_dictionary['Flags']['PPC'].upper()))
        fo.write("    Patch CDR Negative Charge (PNC): %f (%s flag)\n"
                 % (tap_dictionary['PNC'], tap_dictionary['Flags']['PNC'].upper()))

        # Web output graphs
        if web:
            from theraprofnano.Plotters.CDRLen_D3_Template import cdr_graph
            from theraprofnano.Plotters.CDR3Len_D3_Template import cdr3_len_graph
            from theraprofnano.Plotters.CDR3Conf_D3_Template import cdr3_conf_graph
            from theraprofnano.Plotters.PSH_D3_Template import psh_graph
            from theraprofnano.Plotters.PPC_D3_Template import ppc_graph
            from theraprofnano.Plotters.PNC_D3_Template import pnc_graph

            flag2hex = {"red": "#FF0000", "amber": "#FFA500", "green": "#5CBE67"}

            # CDR LENGTH GRAPH
            cdr_graph['data']['data01'][0][5] = tap_dictionary['Total CDR Length']
            cdr_graph['data']['data01'][1][5] = tap_dictionary['Total CDR Length']
            cdr_graph['axes'][0]['lines'][4]['color'] = flag2hex[tap_dictionary['Flags']['L']]
            with open(os.path.join(output, "CDRLen_D3_Template.json"), "w") as fw:
                json.dump(cdr_graph, fw)

            # CDR3 LENGTH GRAPH
            cdr3_len_graph['data']['data01'][0][5] = tap_dictionary['CDRH3 Length']
            cdr3_len_graph['data']['data01'][1][5] = tap_dictionary['CDRH3 Length']
            cdr3_len_graph['axes'][0]['lines'][4]['color'] = flag2hex[tap_dictionary['Flags']['L3']]
            with open(os.path.join(output, "CDR3Len_D3_Template.json"), "w") as fw:
                json.dump(cdr3_len_graph, fw)

            # CDR3 COMPACTNESS GRAPH
            cdr3_conf_graph['data']['data01'][0][5] = tap_dictionary['CDRH3 Compactness']
            cdr3_conf_graph['data']['data01'][1][5] = tap_dictionary['CDRH3 Compactness']
            cdr3_conf_graph['axes'][0]['lines'][4]['color'] = flag2hex[tap_dictionary['Flags']['C']]
            with open(os.path.join(output, "CDR3Conf_D3_Template.json"), "w") as fw:
                json.dump(cdr3_conf_graph, fw)

            # PSH GRAPH
            psh_graph['data']['data01'][0][5] = tap_dictionary['PSH']
            psh_graph['data']['data01'][1][5] = tap_dictionary['PSH']
            psh_graph['axes'][0]['lines'][4]['color'] = flag2hex[tap_dictionary['Flags']['PSH']]
            with open(os.path.join(output, "PSH_D3_Template.json"), "w") as fw:
                json.dump(psh_graph, fw)

            # PPC GRAPH
            ppc_graph['data']['data01'][0][3] = tap_dictionary['PPC']
            ppc_graph['data']['data01'][1][3] = tap_dictionary['PPC']
            ppc_graph['axes'][0]['lines'][2]['color'] = flag2hex[tap_dictionary['Flags']['PPC']]
            with open(os.path.join(output, "PPC_D3_Template.json"), "w") as fw:
                json.dump(ppc_graph, fw)

            # PNC GRAPH
            pnc_graph['data']['data01'][0][3] = tap_dictionary['PNC']
            pnc_graph['data']['data01'][1][3] = tap_dictionary['PNC']
            pnc_graph['axes'][0]['lines'][2]['color'] = flag2hex[tap_dictionary['Flags']['PNC']]
            with open(os.path.join(output, "PNC_D3_Template.json"), "w") as fw:
                json.dump(pnc_graph, fw)

    return tap_dictionary


####################################################################################################
####################################################################################################
####################################################################################################

if __name__ == "__main__":

    parser = argparse.ArgumentParser(description="TAP - Therapeutic Antibody Profiler")

    parser.add_argument('--hscale', dest='h_scale', default=0,
                        help='Hydrophobicity Scale: 0 Kyte-Doolittle, 1 Wimley-White, '
                             '2 Hessa et al, 3 Eisenberg-McLachlan, 4 Black-Mould. Default: 0.')
    parser.add_argument('--name', dest='name', default='Ab1',
                        help='Antibody name. Default: Ab1.')
    parser.add_argument('--output', dest='output', help='Output directory',
                        default='TAP_output', type=os.path.abspath)
    parser.add_argument('--web', '-w', action='store_true', default=False,
                        help="Web front-end mode: write JSON plot files.", dest="web")
    parser.add_argument('--verbose', '-v', action='store_true', default=False,
                        help="Verbose output.", dest="verbose")
    parser.add_argument('--ncores', dest='ncores', default=1,
                        help='Number of cores.')

    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument('--seq', '-s', dest='heavy_sequence',
                       help='Heavy chain (VH) sequence. Use with --seq_light.')
    group.add_argument('--file', '-f', dest='file',
                       help='FASTA file with antibody sequences (heavy/light pairs).',
                       type=os.path.abspath)

    parser.add_argument('--seq_light', '-l', dest='light_sequence', default=None,
                        help='Light chain (VL) sequence. Required when using --seq.')

    args = parser.parse_args()

    h_scale = int(args.h_scale)
    output = str(args.output)
    web = args.web
    verbose = args.verbose
    ncores = int(args.ncores)
    start = time.time()

    # Validate: antibody mode requires both heavy and light
    if args.heavy_sequence and not args.light_sequence:
        sys.exit("Error: --seq_light/-l is required. TAP needs both VH and VL sequences for antibody profiling.")

    # Make output directory
    if os.path.exists(output) is False:
        os.makedirs(output)
    os.chdir(output)
    if os.path.exists(os.path.join(output, "Raw_Model_Outputs")) is False:
        os.mkdir("Raw_Model_Outputs")
    if os.path.exists(os.path.join(output, "Final_Models")) is False:
        os.mkdir("Final_Models")

    hscale_names = {0: "Kyte & Doolittle", 1: "Wimley & White", 2: "Hessa et al.",
                    3: "Eisenberg & McLachlan", 4: "Black & Mould"}
    print("The hydrophobicity scale is set to %s" % hscale_names.get(h_scale, str(h_scale)))

    if args.name:
        name = str(args.name)

    sequences = {}

    # ---- Single sequence input ----
    if args.heavy_sequence:
        heavy_seq = str(args.heavy_sequence).upper()
        light_seq = str(args.light_sequence).upper()
        heavy_name = name + "_H"
        light_name = name + "_L"

        print("You have chosen the single sequence option (antibody mode).")
        print("Antibody name: " + name)
        print("Heavy chain (VH): " + heavy_seq[:60] + "..." if len(heavy_seq) > 60 else "Heavy chain (VH): " + heavy_seq)
        print("Light chain (VL): " + light_seq[:60] + "..." if len(light_seq) > 60 else "Light chain (VL): " + light_seq)
        print(linedivide)

        sequences[name] = {
            "heavy_name": heavy_name,
            "heavy_chain": heavy_seq,
            "light_name": light_name,
            "light_chain": light_seq,
        }

        results_dict = {
            name: main(heavy_name, heavy_seq, light_name, light_seq,
                       h_scale, output, web, verbose)
        }
        with open("TAP_Results_SingleSeqEntry_" + name + ".json", "w") as fo:
            json.dump(results_dict, fo)

    # ---- FASTA file input ----
    elif args.file:
        results_dict = {}
        print("You have chosen to supply your sequences in a FASTA file (antibody mode).")
        print("Sequences are expected in heavy/light pairs.")

        try:
            fasta_records = list(SeqIO.parse(args.file, "fasta"))

            if len(fasta_records) % 2 != 0:
                sys.exit("Error: FASTA file must have an even number of sequences "
                         "(heavy/light pairs).")

            for i in range(0, len(fasta_records), 2):
                heavy_record = fasta_records[i]
                light_record = fasta_records[i + 1]
                seqid = heavy_record.id
                sequences[seqid] = {
                    "heavy_name": heavy_record.id + "_H",
                    "heavy_chain": str(heavy_record.seq),
                    "light_name": light_record.id + "_L",
                    "light_chain": str(light_record.seq),
                }

            print("The FASTA file contains %d antibody pairs." % len(sequences))
            print("TAP will use %d core(s)." % ncores)
            print(linedivide)
        except Exception as e:
            sys.exit("Error reading FASTA file: " + str(e))

        if ncores <= 1:
            for seqid in sequences:
                s = sequences[seqid]
                results_dict[seqid] = main(
                    s["heavy_name"], s["heavy_chain"],
                    s["light_name"], s["light_chain"],
                    h_scale, output, web, verbose)
        else:
            job_params = {}
            for seqid in sequences:
                s = sequences[seqid]
                job_params[seqid] = [
                    s["heavy_name"], s["heavy_chain"],
                    s["light_name"], s["light_chain"],
                    h_scale, output, web, verbose
                ]
            pool = mp.Pool(ncores)
            j_list = [pool.apply_async(main, args=tuple(blah)) for blah in list(job_params.values())]
            mp_results = [j.get() for j in j_list]

            results_dict = {}
            for r in mp_results:
                if r:
                    results_dict[r['name']] = r

        with open("TAP_Results_Multientry.json", "w") as fo:
            json.dump(results_dict, fo)

    elapsed = (time.time() - start)
    print(linedivide)
    print("TAP is Complete! It took %.2fs running on %d core(s).\n" % (elapsed, ncores))

    # Print results summary
    if args.heavy_sequence or args.file:
        for seqid in sequences:
            if seqid in results_dict and results_dict[seqid] != {}:
                r = results_dict[seqid]
                print("\n")
                print("Summary Statistics for %s (antibody):\n" % seqid)
                print("    Total IMGT CDR Length (H+L): %d (%s flag)"
                      % (r['Total CDR Length'], r['Flags']['L'].upper()))
                print("      Heavy chain: %d" % r['Total CDR Length H'])
                print("      Light chain: %d" % r['Total CDR Length L'])
                print("    IMGT CDRH3 Length: %d (%s flag)"
                      % (r['CDRH3 Length'], r['Flags']['L3'].upper()))
                print("    IMGT CDRL3 Length: %d" % r['CDRL3 Length'])
                print("    CDRH3 Compactness: %f (%s flag)"
                      % (r['CDRH3 Compactness'], r['Flags']['C'].upper()))
                print("    PSH: %f (%s flag)"
                      % (r['PSH'], r['Flags']['PSH'].upper()))
                print("    PPC: %f (%s flag)"
                      % (r['PPC'], r['Flags']['PPC'].upper()))
                print("    PNC: %f (%s flag)"
                      % (r['PNC'], r['Flags']['PNC'].upper()))
            else:
                print("TAP crashed on sequence %s\n" % seqid)

        print(linedivide)
