# REQUIRED MODULES
from theraprofnano.TAP.TAP_CDR_Assigner import main as tap_region_and_aa_dicts
from theraprofnano.TAP.TAP_CDR3_Conf_Assigner import main_compactness as tap_compactness_calc
from theraprofnano.TAP.TAP_Hydrophobicity_Assigner import CreateAnnotation as tap_hydrophob_and_charge_calc
import numpy as np
from Bio import SeqIO
import subprocess, time, re, argparse, json, os, sys, shutil
import multiprocessing as mp
import os, glob
from anarci import run_anarci

####################################################################################################

columns = 100
linedivide = "\n\n" + ("-" * columns) + "\n\n"

header = linedivide + """

---------------------------------------------------------------------------------------------------------
